{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/activate",
      "destination": "/activate.html"
    },
    {
      "source": "/company",
      "destination": "/company.html"
    }
    {
      "source": "/arranger",
      "destination": "/arranger.html"
    }
    {
      "source": "/growth-loops",
      "destination": "/growth-loops.html"
    }

  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
